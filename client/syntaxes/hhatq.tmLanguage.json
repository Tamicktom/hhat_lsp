{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "H-hat",
  "scopeName": "source.hhatq",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#function-definition" },
    { "include": "#supertype-definition" },
    { "include": "#modifier-definition" },
    { "include": "#type-definition" },
    { "include": "#const-definition" },
    { "include": "#return-operator" },
    { "include": "#keywords" },
    { "include": "#boolean-literals" },
    { "include": "#self-keyword" },
    { "include": "#types" },
    { "include": "#builtins" },
    { "include": "#type-annotation" },
    { "include": "#function-call" },
    { "include": "#operators" },
    { "include": "#numbers" },
    { "include": "#identifiers" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.hhatq",
          "match": "//.*$"
        },
        {
          "name": "comment.block.hhatq",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.hhatq",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.hhatq",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "function-definition": {
      "patterns": [
        {
          "match": "\\b(fn|metafn)\\s+([#!%@]?[a-zA-Z][a-zA-Z0-9_-]*)",
          "captures": {
            "1": { "name": "storage.type.function.hhatq" },
            "2": { "name": "entity.name.function.hhatq" }
          }
        }
      ]
    },
    "supertype-definition": {
      "patterns": [
        {
          "match": "(?<![a-zA-Z0-9_-])(super-type)\\s+([#!%@]?[a-zA-Z][a-zA-Z0-9_-]*)",
          "captures": {
            "1": { "name": "storage.type.hhatq" },
            "2": { "name": "entity.name.type.hhatq" }
          }
        }
      ]
    },
    "modifier-definition": {
      "patterns": [
        {
          "match": "\\b(modifier)\\s+([#!%@]?[a-zA-Z][a-zA-Z0-9_-]*|\\*|&|\\.\\.\\.)",
          "captures": {
            "1": { "name": "storage.type.function.hhatq" },
            "2": { "name": "entity.name.function.hhatq" }
          }
        }
      ]
    },
    "type-definition": {
      "patterns": [
        {
          "match": "\\b(type)\\s+([a-zA-Z][a-zA-Z0-9_-]*)",
          "captures": {
            "1": { "name": "storage.type.hhatq" },
            "2": { "name": "entity.name.type.hhatq" }
          }
        }
      ]
    },
    "const-definition": {
      "patterns": [
        {
          "match": "\\b(const)\\s+([a-zA-Z][a-zA-Z0-9_-]*)(?:(:)([a-zA-Z][a-zA-Z0-9_-]*))?",
          "captures": {
            "1": { "name": "storage.type.hhatq" },
            "2": { "name": "variable.other.constant.hhatq" },
            "3": { "name": "punctuation.separator.type.hhatq" },
            "4": { "name": "entity.name.type.hhatq" }
          }
        }
      ]
    },
    "return-operator": {
      "patterns": [
        {
          "name": "keyword.control.return.hhatq",
          "match": "::"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.entry.hhatq",
          "match": "\\bmain\\b"
        },
        {
          "name": "keyword.control.import.hhatq",
          "match": "\\buse\\b"
        },
        {
          "name": "storage.type.function.hhatq",
          "match": "\\b(fn|metafn)\\b"
        },
        {
          "name": "storage.type.hhatq",
          "match": "\\b(modifier|type|const)\\b"
        },
        {
          "name": "storage.type.hhatq",
          "match": "(?<![a-zA-Z0-9_-])super-type(?![a-zA-Z0-9_-])"
        }
      ]
    },
    "boolean-literals": {
      "patterns": [
        {
          "name": "constant.language.boolean.hhatq",
          "match": "\\b(true|false)\\b"
        }
      ]
    },
    "self-keyword": {
      "patterns": [
        {
          "name": "variable.language.self.hhatq",
          "match": "\\bself\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "support.type.primitive.hhatq",
          "match": "\\b(i8|i16|i32|i64|u8|u16|u32|u64|f32|f64)\\b"
        }
      ]
    },
    "builtins": {
      "patterns": [
        {
          "name": "support.function.builtin.hhatq",
          "match": "\\b(print)\\b"
        }
      ]
    },
    "type-annotation": {
      "patterns": [
        {
          "match": "([#!%@]?[a-zA-Z][a-zA-Z0-9_-]*)(:)([a-zA-Z][a-zA-Z0-9_-]*)",
          "captures": {
            "1": { "name": "variable.other.hhatq" },
            "2": { "name": "punctuation.separator.type.hhatq" },
            "3": { "name": "entity.name.type.hhatq" }
          }
        }
      ]
    },
    "function-call": {
      "patterns": [
        {
          "match": "\\b([a-zA-Z_][a-zA-Z0-9_.-]*)\\s*(?=\\()",
          "captures": {
            "1": { "name": "entity.name.function.call.hhatq" }
          }
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.assignment.hhatq",
          "match": "="
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.hhatq",
          "match": "\\b\\d+(?:\\.\\d+)?\\b"
        }
      ]
    },
    "identifiers": {
      "patterns": [
        {
          "name": "variable.other.hhatq",
          "match": "[#!%@][a-zA-Z][a-zA-Z0-9_-]*"
        },
        {
          "name": "variable.other.hhatq",
          "match": "\\b[a-zA-Z_][a-zA-Z0-9_-]*\\b"
        }
      ]
    }
  }
}
