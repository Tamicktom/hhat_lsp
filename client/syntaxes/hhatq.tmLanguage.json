{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "H-hat",
  "scopeName": "source.hhatq",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#main-block"
    },
    {
      "include": "#declaration"
    },
    {
      "include": "#builtins"
    },
    {
      "include": "#types"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#identifiers"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.hhatq",
          "match": "//.*$"
        },
        {
          "name": "comment.block.hhatq",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.hhatq",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.hhatq",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "main-block": {
      "patterns": [
        {
          "name": "keyword.control.entry.hhatq",
          "match": "\\bmain\\b"
        }
      ]
    },
    "declaration": {
      "patterns": [
        {
          "name": "meta.assignment.hhatq",
          "match": "(\\w+)\\s*(=)\\s*",
          "captures": {
            "1": { "name": "variable.other.hhatq" },
            "2": { "name": "keyword.operator.assignment.hhatq" }
          }
        }
      ]
    },
    "builtins": {
      "patterns": [
        {
          "name": "support.function.builtin.hhatq",
          "match": "\\b(print)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "storage.type.hhatq",
          "match": "\\b(i8|i16|i32|i64|u8|u16|u32|u64|f32|f64)\\b"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.hhatq",
          "match": "\\b\\d+(?:\\.\\d+)?\\b"
        }
      ]
    },
    "identifiers": {
      "patterns": [
        {
          "name": "variable.other.hhatq",
          "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b"
        }
      ]
    }
  }
}
