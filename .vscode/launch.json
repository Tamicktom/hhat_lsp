{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Extension (H-hat LSP)",
      "type": "extensionHost",
      "request": "launch",
      "runtimeExecutable": "${execPath}",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}/client"
      ],
      "outFiles": [
        "${workspaceFolder}/client/dist/**/*.js",
        "${workspaceFolder}/server/dist/**/*.js"
      ],
      "preLaunchTask": "npm: build"
    }
  ]
}
